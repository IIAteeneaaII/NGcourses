# ── Dominio ───────────────────────────────────────────────────────────────────
DOMAIN=nextgenia.lat
STACK_NAME=ngcourses
PROJECT_NAME=NGcourses
ENVIRONMENT=production

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CAMBIAR

# ── Auth / Cookies ────────────────────────────────────────────────────────────
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_HTTPONLY=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=nextgenia.lat
AUTH_COOKIE_PATH=/
AUTH_VERIFY_JWT=true
AUTH_LEGACY_ROLE_COOKIES=false

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_HOST=https://app.nextgenia.lat
BACKEND_CORS_ORIGINS=https://app.nextgenia.lat

# ── Base de datos ─────────────────────────────────────────────────────────────
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=ngcourses
POSTGRES_PASSWORD=CAMBIAR
POSTGRES_DB=ngcourses

# ── Superusuario inicial ──────────────────────────────────────────────────────
FIRST_SUPERUSER=admin@nextgenia.lat
FIRST_SUPERUSER_PASSWORD=CAMBIAR

# ── Correo (Gmail con contraseña de aplicación) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_SSL=false
SMTP_USER=CAMBIAR@gmail.com
SMTP_PASSWORD=CAMBIAR
EMAILS_FROM_EMAIL=CAMBIAR@gmail.com
EMAILS_FROM_NAME=NGcourses
EMAILS_ENABLED=true

# ── Traefik dashboard ─────────────────────────────────────────────────────────
# Generar HASHED_PASSWORD con: htpasswd -nb admin TU_PASSWORD
USERNAME=admin
HASHED_PASSWORD=CAMBIAR
EMAIL=CAMBIAR@gmail.com

# ── Bunny.net (videos CDN) ────────────────────────────────────────────────────
BUNNY_API_KEY=CAMBIAR
BUNNY_TOKEN_KEY=CAMBIAR
BUNNY_LIBRARY_ID=CAMBIAR
BUNNY_CDN_HOSTNAME=CAMBIAR.b-cdn.net
BUNNY_WEBHOOK_SECRET=CAMBIAR

# ── Sentry (opcional, dejar vacío en beta) ────────────────────────────────────
SENTRY_DSN=

# ── PayPal (dejar vacío en beta) ──────────────────────────────────────────────
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_MODE=sandbox
NEXT_PUBLIC_PAYPAL_CURRENCY=MXN
