# ── Dominio ───────────────────────────────────────────────────────────────────
DOMAIN=nextgenia.lat
STACK_NAME=ngcourses
PROJECT_NAME="NextGen Course"
ENVIRONMENT=production

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CAMBIAR

# ── TLS / HTTPS ───────────────────────────────────────────────────────────────
ENABLE_HTTPS=true

# ── Auth / Cookies ────────────────────────────────────────────────────────────
# AUTH_COOKIE_SAMESITE: lax (si PayPal redirect necesita volver al site) | strict
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=.nextgenia.lat   # punto inicial = válido para todos los subdominios

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_HOST=https://app.nextgenia.lat
BACKEND_CORS_ORIGINS=https://app.nextgenia.lat

# ── Base de datos ─────────────────────────────────────────────────────────────
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=ngcourses
POSTGRES_PASSWORD=CAMBIAR
POSTGRES_DB=ngcourses

# ── Superusuario inicial ──────────────────────────────────────────────────────
FIRST_SUPERUSER=admin@nextgenia.lat
FIRST_SUPERUSER_PASSWORD=CAMBIAR

# ── Correo ────────────────────────────────────────────────────────────────────
# RECOMENDADO (evita spam): Resend con dominio remitente verificado + SPF/DKIM/DMARC.
# Si RESEND_API_KEY está definido, la app usa Resend y NO usa el SMTP de abajo.
#   1) Verifica un subdominio remitente en Resend (ej. mail.nextgenia.lat).
#   2) Publica los registros DNS que te da Resend: SPF (TXT), DKIM (CNAME/TXT) y DMARC (TXT).
#   3) EMAILS_FROM_EMAIL debe ser de ese dominio verificado (ej. no-reply@mail.nextgenia.lat).
# RESEND_API_KEY=re_xxxxxxxx
#
# Fallback SMTP (Gmail con contraseña de aplicación). OJO: enviar desde @gmail.com
# a otros dominios suele caer en spam por falta de alineación SPF/DKIM/DMARC.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_SSL=false
SMTP_USER=CAMBIAR@gmail.com
SMTP_PASSWORD=CAMBIAR
EMAILS_FROM_EMAIL=CAMBIAR@gmail.com
EMAILS_FROM_NAME="NextGen Course"
EMAILS_ENABLED=true

# ── Traefik dashboard ─────────────────────────────────────────────────────────
# Generar HASHED_PASSWORD con: htpasswd -nb admin TU_PASSWORD
USERNAME=admin
HASHED_PASSWORD=CAMBIAR
EMAIL=CAMBIAR@gmail.com

# ── Bunny.net (videos CDN) ────────────────────────────────────────────────────
BUNNY_API_KEY=CAMBIAR
BUNNY_TOKEN_KEY=CAMBIAR
BUNNY_LIBRARY_ID=CAMBIAR
BUNNY_CDN_HOSTNAME=CAMBIAR.b-cdn.net
# Mínimo 32 caracteres. Generar con: python -c "import secrets; print(secrets.token_hex(32))"
BUNNY_WEBHOOK_SECRET=CAMBIAR_minimo_32_caracteres_generar_con_secrets

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=        # igual que SENTRY_DSN pero expuesto al browser
NEXT_PUBLIC_ENVIRONMENT=production

# ── PayPal (dejar vacío en beta) ──────────────────────────────────────────────
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_MODE=sandbox
NEXT_PUBLIC_PAYPAL_CURRENCY=MXN
