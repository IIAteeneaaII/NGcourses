# Copiar este archivo a .env.local y ajustar los valores.
# .env.local está en .gitignore y nunca se commitea.

# Dejar vacío: fetch() del cliente usa rutas relativas (/api/v1/...)
# que Next.js proxea al backend mediante BACKEND_URL (servidor).
NEXT_PUBLIC_API_URL=

# URL del backend para los rewrites del servidor Next.js.
# Dev local (next dev o docker-compose.yml):  http://localhost:8000
# Docker Compose local con red interna:       http://backend:8000
BACKEND_URL=http://localhost:8000

# ID de librería Bunny.net — ver https://dash.bunny.net/
# Debe coincidir con BUNNY_LIBRARY_ID del backend.
NEXT_PUBLIC_BUNNY_LIBRARY_ID=your_library_id_here

# PayPal Sandbox (RF10/RF08)
# 1) Crear cuenta en developer.paypal.com
# 2) My Apps & Credentials -> Sandbox -> Create App
# 3) Copiar el Client ID aqui (NO el Secret — ese va en backend .env como PAYPAL_CLIENT_ID/PAYPAL_SECRET)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_MODE=sandbox
NEXT_PUBLIC_PAYPAL_CURRENCY=MXN
