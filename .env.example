
# ── General ──────────────────────────────────────────────────────────────────
DOMAIN=localhost
STACK_NAME=ngcourses
ENVIRONMENT=local
PROJECT_NAME="NGcourses"

# Generar con:
# openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

FRONTEND_HOST=http://localhost:3000
BACKEND_HOST=http://localhost:8000

# ── AWS / ECR ────────────────────────────────────────────────────────────────
AWS_REGION=us-west-2
ECR_REGISTRY=your_aws_account_id.dkr.ecr.us-west-2.amazonaws.com

# ── Backend ─────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:8000

DOCKER_IMAGE_BACKEND=ngcourses-backend


# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Si backend y PostgreSQL corren en Docker Compose, puede requerirse:
# POSTGRES_SERVER=db
POSTGRES_SERVER=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=ngcourses
POSTGRES_USER=ngcourses
POSTGRES_PASSWORD=change_me


# ── First Superuser ─────────────────────────────────────────────────────────
FIRST_SUPERUSER=admin@ngcourses.com
FIRST_SUPERUSER_PASSWORD=change_me


# ── Auth / JWT / Cookies ────────────────────────────────────────────────────
# Variables preparadas para remediación futura.
# No tendrán efecto completo hasta que el código las consuma directamente.

ACCESS_TOKEN_COOKIE_NAME=access_token
REFRESH_TOKEN_COOKIE_NAME=refresh_token

AUTH_COOKIE_HTTPONLY=true
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/

AUTH_VERIFY_JWT=true
AUTH_LEGACY_ROLE_COOKIES=false


# ── Email Provider ──────────────────────────────────────────────────────────
# Opción A: Resend
RESEND_API_KEY=

# Opción B: SMTP clásico
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=true
SMTP_SSL=false
SMTP_USER=
SMTP_PASSWORD=

EMAILS_FROM_EMAIL=noreply@ngcourses.com
EMAILS_FROM_NAME="NGcourses"


# ── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=


# ── Bunny.net ───────────────────────────────────────────────────────────────
# Obtener credenciales en Bunny.net.
BUNNY_API_KEY=your_bunny_api_key_here
BUNNY_TOKEN_KEY=your_bunny_token_key_here
BUNNY_LIBRARY_ID=your_library_id_here
BUNNY_CDN_HOSTNAME=your-cdn.b-cdn.net
BUNNY_WEBHOOK_SECRET=your_webhook_secret_here


# ── PayPal ──────────────────────────────────────────────────────────────────
# Para desarrollo usar sandbox.
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox


# ── Frontend público ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_BUNNY_LIBRARY_ID=your_library_id_here


# ── Frontend Docker ─────────────────────────────────────────────────────────
DOCKER_IMAGE_FRONTEND=ngcourses-frontend