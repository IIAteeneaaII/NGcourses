# ── General ──────────────────────────────────────────────────────────────────
DOMAIN=localhost
STACK_NAME=ngcourses
ENVIRONMENT=local
PROJECT_NAME="NGcourses"
SECRET_KEY=changethis
FRONTEND_HOST=http://localhost:3000

# ── Backend ─────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173,http://localhost:8000
DOCKER_IMAGE_BACKEND=ngcourses-backend

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_SERVER=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=ngcourses
POSTGRES_USER=ngcourses
POSTGRES_PASSWORD=changethis

# ── First Superuser ─────────────────────────────────────────────────────────
FIRST_SUPERUSER=admin@ngcourses.com
FIRST_SUPERUSER_PASSWORD=changethis

# ── Email ────────────────────────────────────────────────────────────────────
# Opción A (recomendada): Resend — registrarse en https://resend.com
RESEND_API_KEY=
# Opción B: SMTP clásico (si RESEND_API_KEY está vacío)
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@ngcourses.com

# ── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Bunny.net ───────────────────────────────────────────────────────────────
# Obtenga estas credenciales en: https://dash.bunny.net/
BUNNY_API_KEY=your_bunny_api_key_here
BUNNY_TOKEN_KEY=your_bunny_token_key_here
BUNNY_LIBRARY_ID=your_library_id_here
BUNNY_CDN_HOSTNAME=your-cdn.b-cdn.net
# RECOMENDADO: configurar siempre para que el webhook rechace requests no autorizados
BUNNY_WEBHOOK_SECRET=your_webhook_secret_here

# ── Frontend (Next.js) ─────────────────────────────────────────────────────
# Debe coincidir con BUNNY_LIBRARY_ID del backend para que el embed funcione
NEXT_PUBLIC_BUNNY_LIBRARY_ID=your_library_id_here
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Frontend (docker) ──────────────────────────────────────────────────────
DOCKER_IMAGE_FRONTEND=ngcourses-frontend
